#
# bugprone-chained-comparison: Catch2 REQUIRE/CHECK use a decomposer that looks
# like a chained comparison; clang-tidy still reports it in our .cpp (not fixable
# via -header-filter, which only limits diagnostics to OpenPFC headers).

Checks: >
  -*,
  clang-analyzer-*,
  bugprone-*,
  modernize-*,
  performance-*,
  readability-*,
  -readability-identifier-length,
  -modernize-use-trailing-return-type,
  -modernize-use-nodiscard,
  -readability-function-cognitive-complexity,
  -readability-magic-numbers,
  -bugprone-easily-swappable-parameters,
  -bugprone-chained-comparison

WarningsAsErrors: clang-analyzer-*,bugprone-*,modernize-*

CheckOptions:
  - key: readability-identifier-length.AllowedShortNames
    value: dy,dx,dz,i,j,k,x,y,z,t
