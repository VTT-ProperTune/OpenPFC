{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev-debug",
      "displayName": "Dev Debug",
      "generator": "Ninja",
      "binaryDir": "build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "dev-release",
      "displayName": "Dev Release",
      "generator": "Ninja",
      "binaryDir": "build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "analysis",
      "displayName": "Static Analysis (clang-tidy)",
      "inherits": ["dev-debug"],
      "cacheVariables": {
        "USE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "dev-asan",
      "displayName": "Dev Debug (ASan+UBSan)",
      "inherits": ["dev-debug"],
      "binaryDir": "build/asan",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer -g",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer -g",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "tohtori-debug",
      "displayName": "Tohtori (cluster) Debug",
      "inherits": ["dev-debug"],
      "binaryDir": "${sourceDir}/build/tohtori-debug",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/tohtori-gcc11-openmpi.cmake",
        "OpenPFC_ENABLE_CODE_COVERAGE": "OFF"
      },
      "environment": {
        "PATH": "/share/apps/gcc/11.2.0/bin:/share/apps/OpenMPI/4.1.1/bin:$penv{PATH}",
        "LD_LIBRARY_PATH": "/share/apps/gcc/11.2.0/lib:/share/apps/gcc/11.2.0/lib64:/share/apps/gcc/11.2.0/lib/gcc/x86_64-unknown-linux-gnu/11.2.0:/share/apps/OpenMPI/4.1.1/lib:/share/apps/OpenMPI/4.1.1/lib64:$penv{LD_LIBRARY_PATH}"
      }
    },
    {
      "name": "tohtori-release",
      "displayName": "Tohtori (cluster) Release",
      "inherits": ["dev-release"],
      "binaryDir": "${sourceDir}/build/tohtori-release",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/tohtori-gcc11-openmpi.cmake",
        "OpenPFC_ENABLE_CODE_COVERAGE": "OFF"
      },
      "environment": {
        "PATH": "/share/apps/gcc/11.2.0/bin:/share/apps/OpenMPI/4.1.1/bin:$penv{PATH}",
        "LD_LIBRARY_PATH": "/share/apps/gcc/11.2.0/lib:/share/apps/gcc/11.2.0/lib64:/share/apps/gcc/11.2.0/lib/gcc/x86_64-unknown-linux-gnu/11.2.0:/share/apps/OpenMPI/4.1.1/lib:/share/apps/OpenMPI/4.1.1/lib64:$penv{LD_LIBRARY_PATH}"
      }
    },
    {
      "name": "lumi-release",
      "displayName": "LUMI-G (cpeGNU/Cray MPICH) Release",
      "inherits": ["dev-release"],
      "generator": "Unix Makefiles",
      "binaryDir": "/flash/project_462001245/juaho/build/openpfc-lumi-release",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/lumi-gcc12-mpich.cmake",
        "CMAKE_INSTALL_PREFIX": "/projappl/project_462001245/juaho/openpfc",
        "OpenPFC_ENABLE_HIP": "ON",
        "OpenPFC_ENABLE_CODE_COVERAGE": "OFF",
        "OpenPFC_BUILD_DOCUMENTATION": "OFF",
        "OpenPFC_BUILD_TESTS": "OFF",
        "OpenPFC_MPI_HIP_AWARE": "ON",
        "CMAKE_HIP_ARCHITECTURES": "gfx90a"
      },
      "environment": {
        "CMAKE_PREFIX_PATH": "/projappl/project_462001245/heffte/2.4.1-rocm:$penv{CMAKE_PREFIX_PATH}"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev-debug", "configurePreset": "dev-debug" },
    { "name": "dev-release", "configurePreset": "dev-release" },
    { "name": "dev-asan", "configurePreset": "dev-asan" },
    { "name": "analysis", "configurePreset": "analysis" },
    { "name": "tohtori-debug", "configurePreset": "tohtori-debug" },
    { "name": "tohtori-release", "configurePreset": "tohtori-release" },
    { "name": "lumi-release", "configurePreset": "lumi-release" }
  ],
  "testPresets": [
    { "name": "dev", "configurePreset": "dev-debug", "execution": { "jobs": 8 } },
    { "name": "tohtori", "configurePreset": "tohtori-debug", "execution": { "jobs": 8 } }
  ]
}
